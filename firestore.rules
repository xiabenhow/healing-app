rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===================== 調香日曆 =====================
    // 日曆內容：公開可讀（日曆是公開內容），登入者可寫入
    match /calendars/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ===================== Healing App =====================
    // 心情日記：只有登入的使用者可以讀寫自己的日記
    match /diary/{userId}/records/{date} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 心情日記（舊版路徑）
    match /mood_diaries/{docId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 客製化精油訂單
    match /custom_oil_orders/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // 日曆授權驗證
    match /calendar_authorized/{docId} {
      allow read: if request.auth != null;
    }

    // 訂單
    match /orders/{docId} {
      allow read: if request.auth != null;
    }

    // ===================== 會員 & 金流 =====================
    // 會員資料：使用者只能讀取自己的
    match /members/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // 點數歷史
    match /points_history/{docId} {
      allow read: if request.auth != null && request.auth.token.email == resource.data.email;
      allow write: if false;
    }

    // ECPay 回調記錄（只允許 Cloud Functions）
    match /ecpay_callbacks/{docId} {
      allow read, write: if false;
    }

    // LINE Pay 請求記錄
    match /linepay_requests/{docId} {
      allow read, write: if false;
    }

    // LINE Pay 確認記錄
    match /linepay_confirmations/{docId} {
      allow read, write: if false;
    }

    // 發票記錄
    match /invoices/{docId} {
      allow read: if request.auth != null && request.auth.token.email == resource.data.buyerEmail;
      allow write: if false;
    }

    // 預設拒絕所有其他存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
